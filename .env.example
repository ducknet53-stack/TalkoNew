# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GITHUB_TOKEN: Required for Talko AI with GitHub Models (gpt-4o)
GITHUB_TOKEN="MY_GITHUB_TOKEN"

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# VITE_IMGBB_API_KEY: Required for uploading images to ImgBB.
VITE_IMGBB_API_KEY=
